{
  "expo": {
    "name": "curonn",
    "slug": "curronn",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "curonn",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#694664"
      },
      "package": "com.janardhan.reddy.curonn",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBrbqkkwpKdU0qIOkmJm6JnULSDr729oic"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/app-icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-maps"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e91fa092-6f4d-4047-94c7-8fdb5e926871"
      }
    }
  }
}
